{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["ai-conventions/general/*.md"],
  "skills": {
    "paths": [".agents/project-skills"]
  },
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "headers": {
        "Authorization": "Bearer {file:~/.secret/linear/collinson-task.txt}"
      },
      "enabled": true,
      "oauth": false
    },
    "tempo": {
      "type": "remote",
      "url": "http://localhost:5023/api/mcp",
      "enabled": true
    }
  }
}
